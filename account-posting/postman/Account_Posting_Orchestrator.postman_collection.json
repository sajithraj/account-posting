        },
        {
          "name": "DELETE Config Entry",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/account-posting/config/{{configId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "account-posting",
                "config",
                "{{configId}}"
              ]
            },
            "description": "Delete a config entry by configId. Returns HTTP 204 No Content.\nSet the {{configId}} variable or replace in the URL."
          }
        },
        {
          "name": "POST Flush Config Cache",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/account-posting/config/cache/flush",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "account-posting",
                "config",
                "cache",
                "flush"
              ]
            },
            "description": "Evicts the in-memory config cache so the next request reloads from DB.\nCall this after bulk inserts/updates via direct SQL or migrations.\nReturns HTTP 204 No Content."
          }
        }
      ]
    },
    {
      "name": "Account Posting",
      "description": "Core posting operations — create, search, get by ID, retry, and target-system autocomplete.\n\nKey behaviours:\n- sourceName and requestType are validated enums — invalid values → HTTP 400\n- Duplicate endToEndReferenceId → HTTP 422 DUPLICATE_E2E_REF\n- reason field in response: 'Request processed successfully' when all legs succeed, otherwise the last failed leg's error message\n- Retry locks postings for 120 s to prevent concurrent retries",
      "item": [
        {
          "name": "POST Create Posting — IMX CBS+GL",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var rand = Math.floor(Math.random() * 900000) + 100000;",
                  "var ts   = new Date().getTime().toString().slice(-4);",
                  "var now  = new Date();",
                  "var pad  = function(n) { return n < 10 ? '0' + n : '' + n; };",
                  "var today = now.getFullYear() + '-' + pad(now.getMonth() + 1) + '-' + pad(now.getDate());",
                  "pm.variables.set('srcRef',   'SRC-' + rand + '-' + ts);",
                  "pm.variables.set('e2eRef',   'E2E-' + rand + '-' + ts);",
                  "pm.variables.set('amount',   (Math.floor(Math.random() * 999900 + 100) / 100).toFixed(2));",
                  "pm.variables.set('execDate', today);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/account-posting",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "account-posting"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sourceReferenceId\": \"{{srcRef}}\",\n  \"endToEndReferenceId\": \"{{e2eRef}}\",\n  \"sourceName\": \"IMX\",\n  \"requestType\": \"IMX_CBS_GL\",\n  \"amount\": {{amount}},\n  \"currency\": \"USD\",\n  \"creditDebitIndicator\": \"CREDIT\",\n  \"debtorAccount\": \"1324658900\",\n  \"creditorAccount\": \"9875312300\",\n  \"requestedExecutionDate\": \"{{execDate}}\",\n  \"remittanceInformation\": \"Invoice payment INV-2026-001\"\n}"
            },
            "description": "Submit a new posting. Pre-request script auto-generates:\n  sourceReferenceId, endToEndReferenceId — unique per run (SRC/E2E-{random}-{ts})\n  amount — random value between 1.00 and 9999.00\n  requestedExecutionDate — today's date\n\ncreditDebitIndicator: CREDIT | DEBIT\nIdempotency: duplicate endToEndReferenceId → HTTP 422\nResponse includes reason field and leg responses."
          }
        },
