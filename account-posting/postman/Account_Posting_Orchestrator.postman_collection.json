{
  "info": {
    "name": "Account Posting Orchestrator",
    "_postman_id": "apo-collection-v2",
    "description": "Full API collection for the Account Posting Orchestrator service.\n\nBase URL: http://localhost:8080/api\n\nAll responses use the envelope:\n{\n  \"success\": true,\n  \"data\": { ... },\n  \"message\": \"...\",\n  \"timestamp\": \"...\"\n}\n\n--- Enums ---\nsourceName:  IMX | RMS | STABLECOIN\nrequestType: IMX_OBPM | IMX_CBS_GL | FED_RETURN | GL_RETURN | MCA_RETURN | BUY_CUSTOMER_POSTNG | ADD_ACCOUNT_HOLD | CUSTOMER_POSTING\npostingStatus / legStatus: PENDING | SUCCESS | FAILED\ncreditDebitIndicator: CREDIT | DEBIT",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "postingId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "legId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "configId",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Posting Config",
      "description": "Manage routing config — maps sourceName + requestType to ordered target systems with operations.\n\nNotes:\n- orderSeq determines the processing order of legs\n- Cached in memory; call POST /cache/flush after bulk changes\n- Duplicate (requestType + orderSeq) returns HTTP 422",
      "item": [
        {
          "name": "GET All Config Entries",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/account-posting/config",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "account-posting",
                "config"
              ]
            },
            "description": "Returns every row in posting_config ordered by configId."
          }
        },
        {
          "name": "GET Config by Request Type",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/account-posting/config/IMX_CBS_GL",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "account-posting",
                "config",
                "IMX_CBS_GL"
              ]
            },
            "description": "Returns the ordered legs (targetSystem + operation) for a given requestType.\n\nValid requestType values:\n  IMX_OBPM | IMX_CBS_GL | FED_RETURN | GL_RETURN |\n  MCA_RETURN | BUY_CUSTOMER_POSTNG | ADD_ACCOUNT_HOLD | CUSTOMER_POSTING"
          }
        },
        {
          "name": "POST Create Config Entry",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/account-posting/config",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "account-posting",
                "config"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sourceName\": \"IMX\",\n  \"requestType\": \"IMX_CBS_GL\",\n  \"targetSystem\": \"CBS\",\n  \"operation\": \"POSTING\",\n  \"orderSeq\": 1\n}"
            },
            "description": "Add a new config routing entry.\n\nsourceName:   IMX | RMS | STABLECOIN\nrequestType:  IMX_OBPM | IMX_CBS_GL | FED_RETURN | GL_RETURN | MCA_RETURN | BUY_CUSTOMER_POSTNG | ADD_ACCOUNT_HOLD | CUSTOMER_POSTING\ntargetSystem: CBS | GL | OBPM\noperation:    POSTING | ADD_HOLD | CANCEL_HOLD\norderSeq:     1-based integer; determines leg execution order"
          }
        },
