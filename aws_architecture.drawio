    <!-- ───────────── API GATEWAY ───────────── -->
    <mxCell id="11" value="Amazon API Gateway&#xa;REST API (Sync)" style="rounded=1;whiteSpace=wrap;fillColor=#FF9900;strokeColor=#d6b656;fontColor=#ffffff;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="240" y="275" width="145" height="60" as="geometry" />
    </mxCell>

    <!-- ───────────── LAMBDA MAIN (API Handler) ───────────── -->
    <mxCell id="12" value="Payment Orchestration Lambda  |  Java 17 + SnapStart" style="swimlane;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="440" y="80" width="470" height="290" as="geometry" />
    </mxCell>

    <mxCell id="13" value="&lt;b&gt;POST /posting&lt;/b&gt;&#xa;1. Validate duplication (endToEndReferenceId)&#xa;   + requestType → 400 if fail&#xa;2. DynamoDB insert&#xa;   Async → status: RECEIVED&#xa;   Sync  → status: PNDG&#xa;   DynamoDB fail → 500&#xa;3a. Async: Publish to SQS (NORM)&#xa;    Return ACSP immediately&#xa;3b. Sync: Process legs inline&#xa;    Return ACSP / RJCT" style="rounded=1;whiteSpace=wrap;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=8;align=left;spacingLeft=5;verticalAlign=top;" vertex="1" parent="12">
      <mxGeometry x="10" y="40" width="220" height="160" as="geometry" />
    </mxCell>

    <mxCell id="14" value="&lt;b&gt;POST /retry&lt;/b&gt;&#xa;1. Fetch non-SUCCESS postings&#xa;   (status: PNDG or RECEIVED)&#xa;   using GSI2 on DynamoDB&#xa;2. For each: read requestPayload&#xa;   from account_posting table&#xa;3. Publish to SQS&#xa;   (requestMode: RETRY)&#xa;4. Return 202 Accepted&#xa;   immediately to caller" style="rounded=1;whiteSpace=wrap;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=8;align=left;spacingLeft=5;verticalAlign=top;" vertex="1" parent="12">
      <mxGeometry x="240" y="40" width="220" height="160" as="geometry" />
    </mxCell>

    <mxCell id="15" value="&lt;b&gt;POST /search&lt;/b&gt;&#xa;DynamoDB GSI query&#xa;Equality + date range only&#xa;Cursor pagination (nextPageToken)" style="rounded=1;whiteSpace=wrap;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=8;align=left;spacingLeft=5;verticalAlign=top;" vertex="1" parent="12">
      <mxGeometry x="10" y="220" width="220" height="60" as="geometry" />
    </mxCell>

    <mxCell id="16" value="&lt;b&gt;/config CRUD&lt;/b&gt;&#xa;GET / POST / PUT / DELETE&#xa;PostingConfig via Parameter Store" style="rounded=1;whiteSpace=wrap;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=8;align=left;spacingLeft=5;verticalAlign=top;" vertex="1" parent="12">
      <mxGeometry x="240" y="220" width="220" height="60" as="geometry" />
    </mxCell>

    <!-- ───────────── SQS ───────────── -->
    <mxCell id="20" value="&lt;b&gt;Amazon SQS — Processing Queue&lt;/b&gt;&#xa;&#xa;Message structure:&#xa;{&#xa;  postingId:     Long,&#xa;  requestPayload: { full incoming request },&#xa;  requestMode:   NORM | RETRY&#xa;}&#xa;&#xa;Batch Size:          5&#xa;Max Receive Count:   1  (no auto-retry)&#xa;Visibility Timeout:  3 minutes&#xa;DLQ:                 None" style="rounded=1;whiteSpace=wrap;fillColor=#E91E8C;strokeColor=#9c1261;fontColor=#ffffff;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="460" y="430" width="240" height="215" as="geometry" />
    </mxCell>

    <!-- ───────────── PARAMETER STORE ───────────── -->
    <mxCell id="17" value="&lt;b&gt;AWS Systems Manager — Parameter Store&lt;/b&gt;&#xa;&#xa;• PostingConfig per requestType&#xa;  (targetSystem, operation, orderSeq)&#xa;• Source processingMode per sourceName&#xa;  (SYNC / ASYNC)&#xa;• SNS Support Alert Topic ARN&#xa;&#xa;SDK-level caching (no Caffeine / ElastiCache)" style="rounded=1;whiteSpace=wrap;fillColor=#E8D44D;strokeColor=#b5a800;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="990" y="80" width="260" height="170" as="geometry" />
    </mxCell>

    <!-- ───────────── DYNAMODB POSTING ───────────── -->
    <mxCell id="18" value="&lt;b&gt;DynamoDB: account_posting&lt;/b&gt;&#xa;&#xa;PK:   postingId (Number)&#xa;GSI1: endToEndReferenceId → idempotency check&#xa;GSI2: status (PK) + createdAt (SK) → search + retry&#xa;GSI3: sourceName (PK) + createdAt (SK) → search&#xa;&#xa;Key attributes:&#xa;  version, retryLockedUntil, requestPayload,&#xa;  targetSystems, reason, ttl&#xa;&#xa;Status: RECEIVED | PNDG | ACSP | RJCT&#xa;TTL:    60 days (DynamoDB auto-delete)" style="rounded=1;whiteSpace=wrap;fillColor=#647687;strokeColor=#314354;fontColor=#ffffff;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="990" y="285" width="270" height="215" as="geometry" />
    </mxCell>

    <!-- ───────────── DYNAMODB LEG ───────────── -->
    <mxCell id="19" value="&lt;b&gt;DynamoDB: account_posting_leg&lt;/b&gt;&#xa;&#xa;PK: postingId (Number)&#xa;SK: transactionOrder (Number)&#xa;&#xa;Key attributes:&#xa;  targetSystem, account, status,&#xa;  referenceId, reason, attemptNumber,&#xa;  postedTime, mode, operation, version, ttl&#xa;&#xa;mode:   NORM | RETRY | MANUAL&#xa;Status: PNDG | SUCCESS | FAILED&#xa;TTL:    60 days (DynamoDB auto-delete)" style="rounded=1;whiteSpace=wrap;fillColor=#647687;strokeColor=#314354;fontColor=#ffffff;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="990" y="530" width="270" height="210" as="geometry" />
    </mxCell>

    <!-- ───────────── UNIFIED PROCESSOR LAMBDA ───────────── -->
    <mxCell id="21" value="&lt;b&gt;Payment Orchestration Lambda — SQS Event Handler (Unified Processor)&lt;/b&gt;&#xa;&#xa;requestMode = NORM  →  Read PostingConfig from Parameter Store  →  Create legs as PNDG  →  Process each leg (CBS / GL / OBPM)&#xa;requestMode = RETRY →  Fetch non-SUCCESS legs from DynamoDB  →  Reprocess each leg (CBS / GL / OBPM)&#xa;&#xa;Concurrency guard: retryLockedUntil + version attribute via DynamoDB ConditionExpression (atomic CAS)&#xa;All legs SUCCESS → update posting ACSP   |   Any failure → posting stays PNDG + publish failure details to SNS" style="rounded=1;whiteSpace=wrap;fillColor=#FF9900;strokeColor=#d6b656;fontColor=#000000;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="440" y="700" width="750" height="140" as="geometry" />
    </mxCell>

    <!-- ───────────── SNS ───────────── -->
    <mxCell id="22" value="Amazon SNS&#xa;Support Alert Topic&#xa;(Email subscription)" style="rounded=1;whiteSpace=wrap;fillColor=#E74C3C;strokeColor=#c0392b;fontColor=#ffffff;fontSize=10;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="750" y="895" width="190" height="65" as="geometry" />
