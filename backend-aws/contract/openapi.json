{
  "openapi": "3.0.3",
  "info": {
    "title": "backend-aws — Account Posting Creation API",
    "description": "AWS Lambda API for posting creation and async job processing.\n\nHandles a single route:\n  POST /v3/payment/account-posting — validate, persist, and process (sync) or queue (async) a posting.\n\nAll other routes return HTTP 404 from this Lambda. Search, retry, config CRUD, and leg management are handled by backend-ops-aws.\n\nSync vs Async:\n- If all routing configs for the request_type have processingMode=ASYNC, the posting is queued to SQS and the response carries posting_status=ACSP with no legs.\n- If any config has processingMode=SYNC, the posting is processed inline and the response includes posting_status + trimmed leg results.\n\nResponse format: raw JSON (no {success, data, error} envelope).\nError format: {id, name, message}.",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "https://{api_id}.execute-api.ap-southeast-1.amazonaws.com/{stage}",
      "description": "AWS API Gateway",
      "variables": {
        "api_id": {
          "default": "xxxxxxxxxx",
          "description": "API Gateway ID from Terraform output"
        },
        "stage": {
          "default": "dev",
          "enum": ["dev", "staging", "prod"]
        }
      }
    },
    {
      "url": "http://localhost:4566/restapis/{rest_api_id}/dev-local/_user_request_",
      "description": "LocalStack",
      "variables": {
        "rest_api_id": {
          "default": "xxxxxxxxxx"
        }
      }
    }
  ],
  "paths": {
    "/v3/payment/account-posting": {
      "post": {
        "operationId": "createPosting",
        "summary": "Create an account posting",
        "description": "Validates the request, checks idempotency on end_to_end_reference_id, persists the posting, then either processes it inline (SYNC) or queues it to SQS (ASYNC).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IncomingPostingRequest"
              },
              "examples": {
                "imx_async": {
                  "summary": "IMX async posting (CBS + GL legs)",
                  "value": {
                    "source_name": "IMX",
                    "source_reference_id": "SRC-001",
                    "end_to_end_reference_id": "E2E-001",
                    "request_type": "IMX_CBS_GL",
                    "credit_debit_indicator": "DEBIT",
                    "debtor_account": "1000123456",
                    "creditor_account": "1000654321",
                    "requested_execution_date": "2026-04-21",
                    "remittance_information": "Invoice payment",
                    "amount": {
                      "value": "5000.00",
                      "currency_code": "USD"
                    }
                  }
                },
                "stablecoin_sync": {
                  "summary": "STABLECOIN sync posting (CBS ADD_HOLD)",
                  "value": {
                    "source_name": "STABLECOIN",
                    "source_reference_id": "SRC-HOLD-001",
                    "end_to_end_reference_id": "E2E-HOLD-001",
                    "request_type": "ADD_ACCOUNT_HOLD",
                    "credit_debit_indicator": "DEBIT",
                    "debtor_account": "9000111222",
                    "creditor_account": "9000333444",
                    "requested_execution_date": "2026-04-21",
                    "amount": {
                      "value": "1000.00",
                      "currency_code": "USD"
                    }
                  }
                },
                "rms_fed_return": {
                  "summary": "RMS FED_RETURN with optional fields",
                  "value": {
                    "source_name": "RMS",
                    "source_reference_id": "SRC-RMS-001",
                    "end_to_end_reference_id": "E2E-RMS-001",
                    "request_type": "FED_RETURN",
                    "credit_debit_indicator": "CREDIT",
                    "debtor_account": "2000100200",
                    "creditor_account": "2000300400",
                    "requested_execution_date": "2026-04-21",
                    "remittance_information": "Fed wire return",
                    "team_code": "OPS-01",
                    "transaction_code": "TXN-9034",
                    "branch": "BR-NYC",
                    "cif": "CIF-12345",
                    "customer_name": "John Doe",
                    "amount": {
                      "value": "250.00",
                      "currency_code": "USD"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Posting accepted or processed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    { "$ref": "#/components/schemas/PostingResponseAsync" },
                    { "$ref": "#/components/schemas/PostingResponseSync" }
                  ]
                },
                "examples": {
                  "async_accepted": {
                    "summary": "Async — queued to SQS (no legs in response)",
                    "value": {
                      "source_reference_id": "SRC-001",
                      "end_to_end_reference_id": "E2E-001",
                      "posting_status": "ACSP",
                      "processed_at": "2026-04-21T10:00:00Z"
                    }
                  },
                  "sync_success": {
                    "summary": "Sync — processed inline (includes legs)",
                    "value": {
                      "source_reference_id": "SRC-HOLD-001",
                      "end_to_end_reference_id": "E2E-HOLD-001",
                      "posting_status": "ACSP",
                      "processed_at": "2026-04-21T10:01:00Z",
                      "legs": [
                        {
                          "target_system": "CBS",
                          "account": "9000111222",
                          "status": "SUCCESS",
                          "reference_id": "6b9d8304-f09e-431f-a733-c28dc062039d",
                          "posted_time": "2026-04-21T10:01:00.385Z"
                        }
                      ]
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error or unknown request type",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiError" },
                "examples": {
                  "missing_amount": {
                    "value": {
                      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                      "name": "VALIDATION_ERROR",
                      "message": "Request validation failed: amount is required"
                    }
                  },
                  "unknown_type": {
                    "value": {
                      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                      "name": "UNKNOWN_REQUEST_TYPE",
                      "message": "Unknown or unconfigured requestType: FOOBAR"
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Business rule violation",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiError" },
                "examples": {
                  "duplicate": {
                    "value": {
                      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                      "name": "DUPLICATE_E2E_REF",
                      "message": "Posting already exists for endToEndReferenceId: E2E-001"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Technical error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiError" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "IncomingPostingRequest": {
        "type": "object",
        "required": [
          "source_name",
          "source_reference_id",
          "end_to_end_reference_id",
          "request_type",
          "credit_debit_indicator",
          "debtor_account",
          "creditor_account",
          "requested_execution_date",
          "amount"
        ],
        "properties": {
          "source_name": {
            "type": "string",
            "description": "Upstream system name. Must match the sourceName in routing config.",
            "enum": ["IMX", "RMS", "STABLECOIN"],
            "example": "IMX"
          },
          "source_reference_id": {
            "type": "string",
            "description": "Reference ID assigned by the upstream system.",
            "example": "SRC-001"
          },
          "end_to_end_reference_id": {
            "type": "string",
            "description": "End-to-end unique reference. Used for idempotency — duplicate submissions are rejected with 422.",
            "example": "E2E-001"
          },
          "request_type": {
            "type": "string",
            "description": "Identifies which routing config to use. Must be present in the config table.",
            "enum": ["IMX_CBS_GL", "IMX_OBPM", "FED_RETURN", "GL_RETURN", "MCA_RETURN", "BUY_CUSTOMER_POSTING", "ADD_ACCOUNT_HOLD", "CUSTOMER_POSTING"],
            "example": "IMX_CBS_GL"
          },
          "credit_debit_indicator": {
            "type": "string",
            "enum": ["CREDIT", "DEBIT"],
            "example": "DEBIT"
          },
          "debtor_account": {
            "type": "string",
            "description": "Account to debit.",
            "example": "1000123456"
          },
          "creditor_account": {
            "type": "string",
            "description": "Account to credit.",
            "example": "1000654321"
          },
          "requested_execution_date": {
            "type": "string",
            "format": "date",
            "description": "Requested execution date (ISO 8601 date).",
            "example": "2026-04-21"
          },
          "remittance_information": {
            "type": "string",
            "description": "Optional payment description.",
            "example": "Invoice payment"
          },
          "amount": {
            "$ref": "#/components/schemas/Amount"
          },
          "team_code": {
            "type": "string",
            "description": "Optional team/department code for routing or audit.",
            "example": "OPS-01"
          },
          "transaction_code": {
            "type": "string",
            "description": "Optional transaction code passed to the target system.",
            "example": "TXN-9034"
          },
          "branch": {
            "type": "string",
            "description": "Optional branch identifier.",
            "example": "BR-NYC"
          },
          "cif": {
            "type": "string",
            "description": "Optional customer CIF (Customer Information File) number.",
            "example": "CIF-12345"
          },
          "customer_name": {
            "type": "string",
            "description": "Optional customer name.",
            "example": "John Doe"
          }
        }
      },
      "Amount": {
        "type": "object",
        "required": ["value", "currency_code"],
        "properties": {
          "value": {
            "type": "string",
            "description": "Decimal amount as string. Must be > 0.",
            "example": "5000.00"
          },
          "currency_code": {
            "type": "string",
            "description": "ISO 4217 3-letter currency code.",
            "minLength": 3,
            "maxLength": 3,
            "example": "USD"
          }
        }
      },
      "PostingResponseAsync": {
        "type": "object",
        "description": "Response for ASYNC postings — queued to SQS, no legs in response.",
        "properties": {
          "source_reference_id": { "type": "string" },
          "end_to_end_reference_id": { "type": "string" },
          "posting_status": {
            "type": "string",
            "enum": ["ACSP"],
            "description": "ACSP — posting accepted and queued to SQS for async processing."
          },
          "processed_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "PostingResponseSync": {
        "type": "object",
        "description": "Response for SYNC postings — processed inline, trimmed leg results included.",
        "properties": {
          "source_reference_id": { "type": "string" },
          "end_to_end_reference_id": { "type": "string" },
          "posting_status": {
            "type": "string",
            "enum": ["ACSP", "RJCT"],
            "description": "ACSP — all legs succeeded. RJCT — one or more legs failed."
          },
          "processed_at": {
            "type": "string",
            "format": "date-time"
          },
          "legs": {
            "type": "array",
            "description": "Trimmed leg results. Only key outcome fields are returned.",
            "items": {
              "$ref": "#/components/schemas/SyncLegResult"
            }
          }
        }
      },
      "SyncLegResult": {
        "type": "object",
        "description": "Trimmed leg result returned in sync posting response.",
        "properties": {
          "target_system": {
            "type": "string",
            "enum": ["CBS", "GL", "OBPM"]
          },
          "account": {
            "type": "string",
            "example": "9000111222"
          },
          "status": {
            "type": "string",
            "enum": ["SUCCESS", "FAILED"],
            "description": "Outcome of this leg."
          },
          "reference_id": {
            "type": "string",
            "description": "Reference ID returned by the target system.",
            "example": "6b9d8304-f09e-431f-a733-c28dc062039d"
          },
          "posted_time": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the target system processed the leg."
          }
        }
      },
      "ApiError": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique error trace ID.",
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          "name": {
            "type": "string",
            "description": "Error code.",
            "example": "VALIDATION_ERROR"
          },
          "message": {
            "type": "string",
            "example": "Request validation failed: amount is required"
          }
        }
      }
    }
  }
}
