{
  "info": {
    "_postman_id": "backend-aws-collection",
    "name": "backend-aws — Account Posting Creation",
    "description": "API collection for the backend-aws Lambda.\n\nHandles:\n  POST /v3/payment/account-posting  — create a new account posting (sync or async)\n\nAll other routes return 404 from this Lambda — they belong to backend-ops-aws.\n\nResponse format: raw JSON (no {success,data,error} wrapper).\nError format: {id, name, message}.\n\nVariables:\n- base_url — LocalStack or API Gateway URL\n- api_path — /v3/payment/account-posting",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:4566/restapis/{{api_id}}/dev-local/_user_request_",
      "type": "string",
      "description": "LocalStack endpoint. Replace with API Gateway URL for AWS."
    },
    {
      "key": "api_id",
      "value": "xxxxxxxxxx",
      "type": "string",
      "description": "API Gateway REST API ID from Terraform output"
    },
    {
      "key": "api_path",
      "value": "/v3/payment/account-posting",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Create Posting — Async (IMX_CBS_GL)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{base_url}}{{api_path}}",
          "host": ["{{base_url}}{{api_path}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source_name\": \"IMX\",\n  \"source_reference_id\": \"SRC-001\",\n  \"end_to_end_reference_id\": \"E2E-001\",\n  \"request_type\": \"IMX_CBS_GL\",\n  \"credit_debit_indicator\": \"DEBIT\",\n  \"debtor_account\": \"1000123456\",\n  \"creditor_account\": \"1000654321\",\n  \"requested_execution_date\": \"2026-04-21\",\n  \"remittance_information\": \"Invoice payment\",\n  \"amount\": {\n    \"value\": \"5000.00\",\n    \"currency_code\": \"USD\"\n  }\n}",
          "options": { "raw": { "language": "json" } }
        },
        "description": "Creates an async posting for IMX_CBS_GL. All configs for this type have processingMode=ASYNC so the posting is queued to SQS. Response has no legs."
      },
      "response": [
        {
          "name": "200 OK — ACSP (async accepted, no legs)",
          "status": "OK",
          "code": 200,
          "body": "{\n  \"source_reference_id\": \"SRC-001\",\n  \"end_to_end_reference_id\": \"E2E-001\",\n  \"posting_status\": \"ACSP\",\n  \"processed_at\": \"2026-04-21T10:00:00Z\"\n}"
        }
      ]
    },
    {
      "name": "Create Posting — Sync (ADD_ACCOUNT_HOLD)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{base_url}}{{api_path}}",
          "host": ["{{base_url}}{{api_path}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source_name\": \"STABLECOIN\",\n  \"source_reference_id\": \"SRC-HOLD-001\",\n  \"end_to_end_reference_id\": \"E2E-HOLD-001\",\n  \"request_type\": \"ADD_ACCOUNT_HOLD\",\n  \"credit_debit_indicator\": \"DEBIT\",\n  \"debtor_account\": \"9000111222\",\n  \"creditor_account\": \"9000333444\",\n  \"requested_execution_date\": \"2026-04-21\",\n  \"amount\": {\n    \"value\": \"1000.00\",\n    \"currency_code\": \"USD\"\n  }\n}",
          "options": { "raw": { "language": "json" } }
        },
        "description": "Creates a sync posting for ADD_ACCOUNT_HOLD. processingMode=SYNC, so the CBS ADD_HOLD leg is executed inline before the response. Response includes trimmed leg results."
      },
      "response": [
        {
          "name": "200 OK — ACSP (sync success, includes legs)",
          "status": "OK",
          "code": 200,
          "body": "{\n  \"source_reference_id\": \"SRC-HOLD-001\",\n  \"end_to_end_reference_id\": \"E2E-HOLD-001\",\n  \"posting_status\": \"ACSP\",\n  \"processed_at\": \"2026-04-21T10:01:00Z\",\n  \"legs\": [\n    {\n      \"target_system\": \"CBS\",\n      \"account\": \"9000111222\",\n      \"status\": \"SUCCESS\",\n      \"reference_id\": \"6b9d8304-f09e-431f-a733-c28dc062039d\",\n      \"posted_time\": \"2026-04-21T10:01:00.385Z\"\n    }\n  ]\n}"
        }
      ]
    },
    {
      "name": "Create Posting — RMS FED_RETURN",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{base_url}}{{api_path}}",
          "host": ["{{base_url}}{{api_path}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source_name\": \"RMS\",\n  \"source_reference_id\": \"SRC-RMS-001\",\n  \"end_to_end_reference_id\": \"E2E-RMS-001\",\n  \"request_type\": \"FED_RETURN\",\n  \"credit_debit_indicator\": \"CREDIT\",\n  \"debtor_account\": \"2000100200\",\n  \"creditor_account\": \"2000300400\",\n  \"requested_execution_date\": \"2026-04-21\",\n  \"amount\": {\n    \"value\": \"250.00\",\n    \"currency_code\": \"USD\"\n  }\n}",
          "options": { "raw": { "language": "json" } }
        }
      }
    },
    {
      "name": "Create Posting — With Optional Fields",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{base_url}}{{api_path}}",
          "host": ["{{base_url}}{{api_path}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source_name\": \"IMX\",\n  \"source_reference_id\": \"SRC-OPT-001\",\n  \"end_to_end_reference_id\": \"E2E-OPT-001\",\n  \"request_type\": \"IMX_CBS_GL\",\n  \"credit_debit_indicator\": \"DEBIT\",\n  \"debtor_account\": \"1000123456\",\n  \"creditor_account\": \"1000654321\",\n  \"requested_execution_date\": \"2026-04-21\",\n  \"remittance_information\": \"Invoice payment with extras\",\n  \"team_code\": \"OPS-01\",\n  \"transaction_code\": \"TXN-9034\",\n  \"branch\": \"BR-NYC\",\n  \"cif\": \"CIF-12345\",\n  \"customer_name\": \"John Doe\",\n  \"amount\": {\n    \"value\": \"7500.00\",\n    \"currency_code\": \"USD\"\n  }\n}",
          "options": { "raw": { "language": "json" } }
        },
        "description": "Shows all optional fields: team_code, transaction_code, branch, cif, customer_name."
      }
    },
    {
      "name": "Create Posting — Validation Error (missing amount)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{base_url}}{{api_path}}",
          "host": ["{{base_url}}{{api_path}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source_name\": \"IMX\",\n  \"source_reference_id\": \"SRC-ERR-001\",\n  \"end_to_end_reference_id\": \"E2E-ERR-001\",\n  \"request_type\": \"IMX_CBS_GL\",\n  \"credit_debit_indicator\": \"DEBIT\",\n  \"debtor_account\": \"1000123456\",\n  \"creditor_account\": \"1000654321\",\n  \"requested_execution_date\": \"2026-04-21\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "description": "Missing amount object — expects HTTP 400 VALIDATION_ERROR."
      },
      "response": [
        {
          "name": "400 Validation Error",
          "status": "Bad Request",
          "code": 400,
          "body": "{\n  \"id\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n  \"name\": \"VALIDATION_ERROR\",\n  \"message\": \"Request validation failed: amount is required\"\n}"
        }
      ]
    },
    {
      "name": "Create Posting — Duplicate E2E Reference",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{base_url}}{{api_path}}",
          "host": ["{{base_url}}{{api_path}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source_name\": \"IMX\",\n  \"source_reference_id\": \"SRC-001\",\n  \"end_to_end_reference_id\": \"E2E-001\",\n  \"request_type\": \"IMX_CBS_GL\",\n  \"credit_debit_indicator\": \"DEBIT\",\n  \"debtor_account\": \"1000123456\",\n  \"creditor_account\": \"1000654321\",\n  \"requested_execution_date\": \"2026-04-21\",\n  \"amount\": {\n    \"value\": \"5000.00\",\n    \"currency_code\": \"USD\"\n  }\n}",
          "options": { "raw": { "language": "json" } }
        },
        "description": "Re-submit the same end_to_end_reference_id — expects HTTP 422 DUPLICATE_E2E_REF."
      },
      "response": [
        {
          "name": "422 Duplicate",
          "status": "Unprocessable Entity",
          "code": 422,
          "body": "{\n  \"id\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n  \"name\": \"DUPLICATE_E2E_REF\",\n  \"message\": \"Posting already exists for endToEndReferenceId: E2E-001\"\n}"
        }
      ]
    },
    {
      "name": "Create Posting — Unknown Request Type",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{base_url}}{{api_path}}",
          "host": ["{{base_url}}{{api_path}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source_name\": \"IMX\",\n  \"source_reference_id\": \"SRC-UNK-001\",\n  \"end_to_end_reference_id\": \"E2E-UNK-001\",\n  \"request_type\": \"UNKNOWN_TYPE\",\n  \"credit_debit_indicator\": \"DEBIT\",\n  \"debtor_account\": \"1000123456\",\n  \"creditor_account\": \"1000654321\",\n  \"requested_execution_date\": \"2026-04-21\",\n  \"amount\": {\n    \"value\": \"100.00\",\n    \"currency_code\": \"USD\"\n  }\n}",
          "options": { "raw": { "language": "json" } }
        },
        "description": "requestType not in config table — expects HTTP 400 UNKNOWN_REQUEST_TYPE."
      },
      "response": [
        {
          "name": "400 Unknown Request Type",
          "status": "Bad Request",
          "code": 400,
          "body": "{\n  \"id\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n  \"name\": \"UNKNOWN_REQUEST_TYPE\",\n  \"message\": \"Unknown or unconfigured requestType: UNKNOWN_TYPE\"\n}"
        }
      ]
    }
  ]
}
