{
  "openapi": "3.0.3",
  "info": {
    "title": "backend-ops-aws — Account Posting Operations API",
    "description": "AWS Lambda API for the operations / dashboard: search, retry, leg management, and routing config CRUD.\n\nDoes NOT handle POST /v3/payment/account-posting (posting creation) — that belongs to backend-aws.\n\nResponse format: raw JSON (no {success, data, error} envelope).\nError format: {id, name, message}.\n\nAll posting IDs are UUID strings.",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "https://{api_id}.execute-api.ap-southeast-1.amazonaws.com/{stage}",
      "description": "AWS API Gateway",
      "variables": {
        "api_id": {
          "default": "xxxxxxxxxx",
          "description": "API Gateway ID from Terraform output"
        },
        "stage": {
          "default": "dev",
          "enum": ["dev", "staging", "prod"]
        }
      }
    },
    {
      "url": "http://localhost:4566/restapis/{rest_api_id}/dev-local/_user_request_",
      "description": "LocalStack",
      "variables": {
        "rest_api_id": {
          "default": "xxxxxxxxxx"
        }
      }
    }
  ],
  "paths": {
    "/v3/payment/account-posting/search": {
      "post": {
        "operationId": "searchPostings",
        "summary": "Search postings",
        "description": "Search the posting table with optional filters. All filter fields are optional. Results are sorted by updated_at descending before pagination and include legs for each posting. Use next_page_token as page_token on the next request. Filters may be supplied in the POST JSON body or as query parameters; GET /search is also exposed for query-string searches.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PostingSearchRequest" },
              "examples": {
                "all": {
                  "summary": "No filters — latest 20",
                  "value": { "limit": 20 }
                },
                "by_status": {
                  "summary": "Filter by PNDG status",
                  "value": { "posting_status": "PNDG", "limit": 20 }
                },
                "next_page": {
                  "summary": "Fetch the next page",
                  "value": { "posting_status": "PNDG", "limit": 20, "page_token": "eyJvZmZzZXQiOjIwfQ" }
                },
                "by_source": {
                  "summary": "Filter by source name",
                  "value": { "source_name": "IMX", "limit": 10 }
                },
                "by_request_type": {
                  "summary": "Filter by request type",
                  "value": { "request_type": "IMX_CBS_GL", "limit": 20 }
                },
                "by_e2e_ref": {
                  "summary": "Filter by end-to-end reference",
                  "value": { "end_to_end_id": "E2E-001", "limit": 1 }
                },
                "by_source_ref": {
                  "summary": "Filter by source reference",
                  "value": { "source_ref_id": "SRC-001", "limit": 1 }
                },
                "by_date": {
                  "summary": "Filter by date range",
                  "value": {
                    "from_date": "2026-04-01T00:00:00Z",
                    "to_date": "2026-04-30T23:59:59Z",
                    "limit": 50
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Page of matching postings (items may be empty)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PostingSearchResponse" }
              }
            }
          }
        }
      }
    },
    "/v3/payment/account-posting/retry": {
      "post": {
        "operationId": "retryPostings",
        "summary": "Retry pending postings",
        "description": "Re-queues postings to SQS for reprocessing. If posting_ids is omitted, all PNDG and RCVD postings are retried. Uses DynamoDB conditional write for retry locking — already-locked postings are skipped.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RetryRequest" },
              "examples": {
                "all_pending": {
                  "summary": "Retry all PNDG/RCVD",
                  "value": { "requested_by": "OPS-USER" }
                },
                "specific": {
                  "summary": "Retry specific posting IDs",
                  "value": {
                    "posting_ids": [
                      "058be267-6679-475e-bbb7-e199fc4c9a32",
                      "c5499148-7297-458e-ad45-cf58d2372d91"
                    ],
                    "requested_by": "OPS-USER"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Retry summary",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RetryResponse" },
                "examples": {
                  "success": {
                    "value": {
                      "total_postings": 5,
                      "queued": 4,
                      "skipped_locked": 1,
                      "message": "Retry processing submitted. Check dashboard for status updates."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v3/payment/account-posting/{id}": {
      "get": {
        "operationId": "getPostingById",
        "summary": "Get posting by ID",
        "description": "Fetches a single posting and all its legs.",
        "parameters": [
          { "$ref": "#/components/parameters/PostingId" }
        ],
        "responses": {
          "200": {
            "description": "Posting found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PostingResponse" },
                "examples": {
                  "found": {
                    "value": {
                      "posting_id": "058be267-6679-475e-bbb7-e199fc4c9a32",
                      "source_reference_id": "SRC-001",
                      "end_to_end_reference_id": "E2E-001",
                      "source_name": "IMX",
                      "request_type": "IMX_CBS_GL",
                      "amount": "5000.00",
                      "currency": "USD",
                      "credit_debit_indicator": "DEBIT",
                      "debtor_account": "1000123456",
                      "creditor_account": "1000654321",
                      "requested_execution_date": "2026-04-21",
                      "remittance_information": "Invoice payment",
                      "posting_status": "ACSP",
                      "target_systems": "CBS,GL",
                      "processed_at": "2026-04-21T10:00:00Z",
                      "created_at": "2026-04-21T10:00:00Z",
                      "updated_at": "2026-04-21T10:00:05Z",
                      "legs": [
                        {
                          "posting_id": "058be267-6679-475e-bbb7-e199fc4c9a32",
                          "transaction_order": 1,
                          "target_system": "CBS",
                          "account": "1000123456",
                          "status": "SUCCESS",
                          "reference_id": "6b9d8304-f09e-431f-a733-c28dc062039d",
                          "attempt_number": 1,
                          "posted_time": "2026-04-21T10:00:03Z",
                          "mode": "NORM",
                          "operation": "POSTING",
                          "created_at": "2026-04-21T10:00:01Z",
                          "updated_at": "2026-04-21T10:00:04Z"
                        }
                      ]
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Posting not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiError" },
                "examples": {
                  "not_found": {
                    "value": {
                      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                      "name": "NOT_FOUND",
                      "message": "Posting not found: 99999999-9999-9999-9999-999999999999"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v3/payment/account-posting/{id}/transaction": {
      "get": {
        "operationId": "listLegs",
        "summary": "List all legs for a posting",
        "parameters": [
          { "$ref": "#/components/parameters/PostingId" }
        ],
        "responses": {
          "200": {
            "description": "Array of legs (may be empty)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/LegResponse" }
                }
              }
            }
          }
        }
      }
    },
    "/v3/payment/account-posting/{id}/transaction/{order}": {
      "get": {
        "operationId": "getLeg",
        "summary": "Get a single leg",
        "parameters": [
          { "$ref": "#/components/parameters/PostingId" },
          { "$ref": "#/components/parameters/TransactionOrder" }
        ],
        "responses": {
          "200": {
            "description": "Leg found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LegResponse" }
              }
            }
          },
          "404": {
            "description": "Leg not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiError" }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "manualUpdateLeg",
        "summary": "Manual leg status override",
        "description": "Overrides the leg status manually. Sets mode=MANUAL and records requestedBy. attemptNumber is NOT incremented — this is a manual correction, not a retry.",
        "parameters": [
          { "$ref": "#/components/parameters/PostingId" },
          { "$ref": "#/components/parameters/TransactionOrder" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ManualUpdateRequest" },
              "examples": {
                "approve": {
                  "summary": "Manually mark as SUCCESS",
                  "value": {
                    "status": "SUCCESS",
                    "reason": "Confirmed by ops team — external system responded via phone",
                    "requested_by": "OPS-USER"
                  }
                },
                "reject": {
                  "summary": "Manually mark as FAILED",
                  "value": {
                    "status": "FAILED",
                    "reason": "Target system confirmed rejection",
                    "requested_by": "OPS-USER"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated leg returned",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LegResponse" }
              }
            }
          },
          "404": {
            "description": "Leg not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiError" }
              }
            }
          }
        }
      }
    },
    "/v3/payment/account-posting/config": {
      "get": {
        "operationId": "listConfigs",
        "summary": "List all routing configs",
        "description": "Returns all routing config entries across all request types.",
        "responses": {
          "200": {
            "description": "Array of config entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/PostingConfig" }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createConfig",
        "summary": "Create a routing config entry",
        "description": "Adds a routing config row. Each requestType can have multiple ordered entries (one per orderSeq).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PostingConfig" },
              "examples": {
                "imx_cbs": {
                  "summary": "IMX → CBS leg 1 (async)",
                  "value": {
                    "request_type": "IMX_CBS_GL",
                    "order_seq": 1,
                    "source_name": "IMX",
                    "target_system": "CBS",
                    "operation": "POSTING",
                    "processing_mode": "ASYNC"
                  }
                },
                "imx_gl": {
                  "summary": "IMX → GL leg 2 (async)",
                  "value": {
                    "request_type": "IMX_CBS_GL",
                    "order_seq": 2,
                    "source_name": "IMX",
                    "target_system": "GL",
                    "operation": "POSTING",
                    "processing_mode": "ASYNC"
                  }
                },
                "hold_sync": {
                  "summary": "STABLECOIN → CBS ADD_HOLD (sync)",
                  "value": {
                    "request_type": "ADD_ACCOUNT_HOLD",
                    "order_seq": 1,
                    "source_name": "STABLECOIN",
                    "target_system": "CBS",
                    "operation": "ADD_HOLD",
                    "processing_mode": "SYNC"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Config entry created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PostingConfig" }
              }
            }
          }
        }
      }
    },
    "/v3/payment/account-posting/config/{requestType}": {
      "get": {
        "operationId": "getConfigByRequestType",
        "summary": "Get configs by request type",
        "parameters": [
          {
            "name": "requestType",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "IMX_CBS_GL"
          }
        ],
        "responses": {
          "200": {
            "description": "Config entries for this request type",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/PostingConfig" }
                }
              }
            }
          }
        }
      }
    },
    "/v3/payment/account-posting/config/{type}/{order}": {
      "put": {
        "operationId": "updateConfig",
        "summary": "Update a routing config entry",
        "parameters": [
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "IMX_CBS_GL"
          },
          {
            "name": "order",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "example": 1
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PostingConfig" },
              "examples": {
                "change_mode": {
                  "summary": "Change processing mode to SYNC",
                  "value": {
                    "request_type": "IMX_CBS_GL",
                    "order_seq": 1,
                    "source_name": "IMX",
                    "target_system": "CBS",
                    "operation": "POSTING",
                    "processing_mode": "SYNC"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated config entry",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PostingConfig" }
              }
            }
          },
          "404": {
            "description": "Config not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiError" }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteConfig",
        "summary": "Delete a routing config entry",
        "parameters": [
          {
            "name": "type",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "IMX_CBS_GL"
          },
          {
            "name": "order",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "example": 1
          }
        ],
        "responses": {
          "204": { "description": "Deleted — no content" },
          "404": {
            "description": "Config not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiError" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "PostingId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        },
        "description": "Posting ID (UUID string)",
        "example": "058be267-6679-475e-bbb7-e199fc4c9a32"
      },
      "TransactionOrder": {
        "name": "order",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "Leg sequence number (1-based)",
        "example": 1
      }
    },
    "schemas": {
      "PostingSearchRequest": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["RCVD", "PNDG", "ACSP", "RJCT"],
            "description": "Filter by posting status. Alias accepted: posting_status."
          },
          "source_name": {
            "type": "string",
            "description": "Filter by source system name.",
            "enum": ["IMX", "RMS", "STABLECOIN"],
            "example": "IMX"
          },
          "request_type": {
            "type": "string",
            "description": "Filter by request type.",
            "example": "IMX_CBS_GL"
          },
          "end_to_end_reference_id": {
            "type": "string",
            "description": "Filter by end-to-end reference ID (exact match via GSI). Alias accepted: end_to_end_id.",
            "example": "E2E-001"
          },
          "source_reference_id": {
            "type": "string",
            "description": "Filter by source reference ID. Alias accepted: source_ref_id.",
            "example": "SRC-001"
          },
          "from_date": {
            "type": "string",
            "format": "date-time",
            "description": "Inclusive start of updated_at range.",
            "example": "2026-04-01T00:00:00Z"
          },
          "to_date": {
            "type": "string",
            "format": "date-time",
            "description": "Inclusive end of updated_at range.",
            "example": "2026-04-30T23:59:59Z"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "default": 20,
            "description": "Max results to return."
          },
          "page_token": {
            "type": "string",
            "description": "Pagination token from a previous response for fetching the next page."
          }
        }
      },
      "RetryRequest": {
        "type": "object",
        "required": ["requested_by"],
        "properties": {
          "posting_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Specific posting IDs (UUIDs) to retry. Omit to retry all PNDG/RCVD."
          },
          "requested_by": {
            "type": "string",
            "description": "Operator identity — stored for audit.",
            "example": "OPS-USER"
          }
        }
      },
      "PostingSearchResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PostingResponse" }
          },
          "next_page_token": {
            "type": "string",
            "description": "Opaque token to pass as page_token on the next request. Omitted when there are no more results."
          }
        }
      },
      "RetryResponse": {
        "type": "object",
        "properties": {
          "total_postings": {
            "type": "integer",
            "description": "Number of candidate postings evaluated."
          },
          "queued": {
            "type": "integer",
            "description": "Postings successfully queued to SQS."
          },
          "skipped_locked": {
            "type": "integer",
            "description": "Postings skipped because retry lock was already held."
          },
          "message": {
            "type": "string",
            "example": "Retry processing submitted. Check dashboard for status updates."
          }
        }
      },
      "PostingResponse": {
        "type": "object",
        "description": "Full posting object as returned by search and get-by-ID. All fields present in DynamoDB are included.",
        "properties": {
          "posting_id": {
            "type": "string",
            "format": "uuid",
            "example": "058be267-6679-475e-bbb7-e199fc4c9a32"
          },
          "source_reference_id": {
            "type": "string",
            "example": "SRC-001"
          },
          "end_to_end_reference_id": {
            "type": "string",
            "example": "E2E-001"
          },
          "source_name": {
            "type": "string",
            "enum": ["IMX", "RMS", "STABLECOIN"],
            "example": "IMX"
          },
          "request_type": {
            "type": "string",
            "example": "IMX_CBS_GL"
          },
          "amount": {
            "type": "string",
            "description": "Decimal amount as string.",
            "example": "5000.00"
          },
          "currency": {
            "type": "string",
            "description": "ISO 4217 3-letter currency code.",
            "example": "USD"
          },
          "credit_debit_indicator": {
            "type": "string",
            "enum": ["CREDIT", "DEBIT"]
          },
          "debtor_account": {
            "type": "string",
            "example": "1000123456"
          },
          "creditor_account": {
            "type": "string",
            "example": "1000654321"
          },
          "requested_execution_date": {
            "type": "string",
            "format": "date",
            "example": "2026-04-21"
          },
          "remittance_information": {
            "type": "string",
            "example": "Invoice payment"
          },
          "posting_status": {
            "type": "string",
            "enum": ["RCVD", "PNDG", "ACSP", "RJCT"],
            "description": "RCVD — received and queued. PNDG — pending processing. ACSP — all legs succeeded. RJCT — one or more legs failed."
          },
          "target_systems": {
            "type": "string",
            "description": "Comma-separated list of target systems for this posting.",
            "example": "CBS,GL"
          },
          "reason": {
            "type": "string",
            "description": "Failure reason when posting_status is RJCT.",
            "example": "CBS leg failed: timeout"
          },
          "processed_at": {
            "type": "string",
            "format": "date-time"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "legs": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/LegResponse" }
          }
        }
      },
      "LegResponse": {
        "type": "object",
        "properties": {
          "posting_id": {
            "type": "string",
            "format": "uuid",
            "example": "058be267-6679-475e-bbb7-e199fc4c9a32"
          },
          "transaction_order": {
            "type": "integer",
            "description": "Execution order within the posting (1-based).",
            "example": 1
          },
          "target_system": {
            "type": "string",
            "enum": ["CBS", "GL", "OBPM"]
          },
          "account": {
            "type": "string",
            "example": "1000123456"
          },
          "status": {
            "type": "string",
            "enum": ["PNDG", "SUCCESS", "FAILED"],
            "description": "PNDG — awaiting processing. SUCCESS — target system accepted. FAILED — target system rejected or error."
          },
          "reference_id": {
            "type": "string",
            "description": "Reference ID returned by the target system.",
            "example": "6b9d8304-f09e-431f-a733-c28dc062039d"
          },
          "reason": {
            "type": "string",
            "description": "Failure reason when status is FAILED.",
            "example": "Connection timeout"
          },
          "attempt_number": {
            "type": "integer",
            "description": "Number of processing attempts (incremented on retry, not on manual update).",
            "example": 1
          },
          "posted_time": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the target system processed the leg."
          },
          "mode": {
            "type": "string",
            "enum": ["NORM", "RETRY", "MANUAL"],
            "description": "NORM — initial processing. RETRY — re-queued retry. MANUAL — ops manual override."
          },
          "operation": {
            "type": "string",
            "enum": ["POSTING", "ADD_HOLD", "REMOVE_HOLD"],
            "description": "Operation type executed on the target system."
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ManualUpdateRequest": {
        "type": "object",
        "required": ["status", "requested_by"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["SUCCESS", "FAILED", "PNDG"],
            "description": "New status to force on the leg."
          },
          "reason": {
            "type": "string",
            "description": "Justification for the manual override."
          },
          "requested_by": {
            "type": "string",
            "description": "Operator identity.",
            "example": "OPS-USER"
          }
        }
      },
      "PostingConfig": {
        "type": "object",
        "required": ["request_type", "order_seq", "target_system", "operation", "processing_mode"],
        "properties": {
          "request_type": {
            "type": "string",
            "description": "Posting type — DynamoDB partition key.",
            "example": "IMX_CBS_GL"
          },
          "order_seq": {
            "type": "integer",
            "description": "Execution order within the requestType — DynamoDB sort key.",
            "example": 1
          },
          "source_name": {
            "type": "string",
            "description": "Expected upstream system name. Blank = any source accepted.",
            "example": "IMX"
          },
          "target_system": {
            "type": "string",
            "enum": ["CBS", "GL", "OBPM"],
            "description": "External system this leg routes to."
          },
          "operation": {
            "type": "string",
            "enum": ["POSTING", "ADD_HOLD", "REMOVE_HOLD"]
          },
          "processing_mode": {
            "type": "string",
            "enum": ["SYNC", "ASYNC"],
            "description": "ASYNC — posting is queued to SQS; caller gets ACSP immediately. SYNC — posting is processed inline before the API response."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          }
        }
      },
      "ApiError": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique error trace ID.",
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          "name": {
            "type": "string",
            "description": "Error code.",
            "example": "NOT_FOUND"
          },
          "message": {
            "type": "string",
            "example": "Posting not found: 99999999-9999-9999-9999-999999999999"
          }
        }
      }
    }
  }
}
