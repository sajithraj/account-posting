{
  "info": {
    "_postman_id": "backend-ops-aws-collection",
    "name": "backend-ops-aws — Account Posting Operations",
    "description": "API collection for the backend-ops-aws Lambda (ops dashboard).\n\nHandles: search, retry, fetch by ID, manual leg override, routing config CRUD.\n\nResponse format: raw JSON (no {success,data,error} wrapper).\nError format: {id, name, message}.\n\nSearch results do NOT include legs. Use GET /{id} to get a posting with its legs.\nLeg PATCH uses transaction_order (integer, 1-based) in the path — not a UUID.\nConfig update/delete use {requestType}/{orderSeq} in the path.\n\nVariables:\n- base_url — LocalStack or API Gateway URL\n- posting_id — replace with an actual UUID from search/create",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:4566/restapis/{{api_id}}/dev-local/_user_request_",
      "type": "string",
      "description": "LocalStack endpoint. Replace with API Gateway URL for AWS."
    },
    {
      "key": "api_id",
      "value": "xxxxxxxxxx",
      "type": "string",
      "description": "API Gateway REST API ID from Terraform output"
    },
    {
      "key": "api_path",
      "value": "/v3/payment/account-posting",
      "type": "string"
    },
    {
      "key": "posting_id",
      "value": "058be267-6679-475e-bbb7-e199fc4c9a32",
      "type": "string",
      "description": "Posting UUID — replace with actual ID from a posting response"
    }
  ],
  "item": [
    {
      "name": "Search",
      "item": [
        {
          "name": "Search — All (no filters, latest 3 days)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}{{api_path}}/search",
              "host": ["{{base_url}}{{api_path}}/search"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"limit\": 20\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Returns up to 20 postings updated in the last 3 days with no filters."
          }
        },
        {
          "name": "Search — By Status (PNDG)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}{{api_path}}/search",
              "host": ["{{base_url}}{{api_path}}/search"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"PNDG\",\n  \"limit\": 20\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Valid status values: RCVD, PNDG, RTRY, ACSP, RJCT."
          }
        },
        {
          "name": "Search — By Source Name (IMX)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}{{api_path}}/search",
              "host": ["{{base_url}}{{api_path}}/search"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_name\": \"IMX\",\n  \"limit\": 10\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Source names: IMX, RMS, STABLECOIN."
          }
        },
        {
          "name": "Search — By Request Type",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}{{api_path}}/search",
              "host": ["{{base_url}}{{api_path}}/search"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"request_type\": \"IMX_CBS_GL\",\n  \"limit\": 20\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Search — By End-to-End Reference",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}{{api_path}}/search",
              "host": ["{{base_url}}{{api_path}}/search"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"end_to_end_reference_id\": \"E2E-001\",\n  \"limit\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Exact match via GSI — fastest lookup when you have the E2E ref."
          }
        },
        {
          "name": "Search — By Source Reference",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}{{api_path}}/search",
              "host": ["{{base_url}}{{api_path}}/search"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_reference_id\": \"SRC-001\",\n  \"limit\": 1\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Search — By Date Range",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}{{api_path}}/search",
              "host": ["{{base_url}}{{api_path}}/search"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from_date\": \"2026-04-01T00:00:00Z\",\n  \"to_date\": \"2026-04-30T23:59:59Z\",\n  \"limit\": 50\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Retry",
      "item": [
        {
          "name": "Retry — Missing Posting IDs (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}{{api_path}}/retry",
              "host": ["{{base_url}}{{api_path}}/retry"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requested_by\": \"OPS-USER\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Bulk retry is not allowed. posting_ids must be provided. Returns 400."
          },
          "response": [
            {
              "name": "400 Bad Request",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"id\": \"generated-error-id\",\n  \"name\": \"POSTING_IDS_REQUIRED\",\n  \"message\": \"posting_ids must be provided for retry; bulk retry is not allowed\"\n}"
            }
          ]
        },
        {
          "name": "Retry — Specific IDs",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}{{api_path}}/retry",
              "host": ["{{base_url}}{{api_path}}/retry"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"posting_ids\": [\"{{posting_id}}\"],\n  \"requested_by\": \"OPS-USER\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "posting_ids are UUID strings. Only PNDG/RCVD postings are eligible."
          }
        }
      ]
    },
    {
      "name": "Postings",
      "item": [
        {
          "name": "Get Posting by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}{{api_path}}/{{posting_id}}",
              "host": ["{{base_url}}{{api_path}}/{{posting_id}}"]
            },
            "description": "Fetch a single posting with all its legs embedded. Each leg includes transaction_order (integer, 1-based) — use that integer in the PATCH leg endpoint."
          },
          "response": [
            {
              "name": "200 OK — full posting with legs",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"posting_id\": \"058be267-6679-475e-bbb7-e199fc4c9a32\",\n  \"source_reference_id\": \"SRC-001\",\n  \"end_to_end_reference_id\": \"E2E-001\",\n  \"source_name\": \"IMX\",\n  \"request_type\": \"IMX_CBS_GL\",\n  \"amount\": \"5000.00\",\n  \"currency\": \"USD\",\n  \"credit_debit_indicator\": \"DEBIT\",\n  \"debtor_account\": \"1000123456\",\n  \"creditor_account\": \"1000654321\",\n  \"requested_execution_date\": \"2026-04-21\",\n  \"remittance_information\": \"Invoice payment\",\n  \"posting_status\": \"ACSP\",\n  \"target_systems\": \"CBS,GL\",\n  \"processed_at\": \"2026-04-21T10:00:05Z\",\n  \"created_at\": \"2026-04-21T10:00:00Z\",\n  \"updated_at\": \"2026-04-21T10:00:05Z\",\n  \"legs\": [\n    {\n      \"posting_id\": \"058be267-6679-475e-bbb7-e199fc4c9a32\",\n      \"transaction_id\": \"6b9d8304-f09e-431f-a733-c28dc062039d\",\n      \"transaction_order\": 1,\n      \"target_system\": \"CBS\",\n      \"account\": \"1000123456\",\n      \"status\": \"SUCCESS\",\n      \"reference_id\": \"6b9d8304-f09e-431f-a733-c28dc062039d\",\n      \"attempt_number\": 1,\n      \"posted_time\": \"2026-04-21T10:00:03Z\",\n      \"mode\": \"NORM\",\n      \"operation\": \"POSTING\",\n      \"created_at\": \"2026-04-21T10:00:01Z\",\n      \"updated_at\": \"2026-04-21T10:00:04Z\"\n    },\n    {\n      \"posting_id\": \"058be267-6679-475e-bbb7-e199fc4c9a32\",\n      \"transaction_id\": \"9f2a1c4d-b3e7-48d9-a012-cd5678901234\",\n      \"transaction_order\": 2,\n      \"target_system\": \"GL\",\n      \"account\": \"1000123456\",\n      \"status\": \"SUCCESS\",\n      \"reference_id\": \"9f2a1c4d-b3e7-48d9-a012-cd5678901234\",\n      \"attempt_number\": 1,\n      \"posted_time\": \"2026-04-21T10:00:04Z\",\n      \"mode\": \"NORM\",\n      \"operation\": \"POSTING\",\n      \"created_at\": \"2026-04-21T10:00:01Z\",\n      \"updated_at\": \"2026-04-21T10:00:05Z\"\n    }\n  ]\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"id\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n  \"name\": \"NOT_FOUND\",\n  \"message\": \"Posting not found: 99999999-9999-9999-9999-999999999999\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Legs",
      "item": [
        {
          "name": "Manual Leg Status Override — SUCCESS (order=1)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}{{api_path}}/{{posting_id}}/transaction/1",
              "host": ["{{base_url}}{{api_path}}/{{posting_id}}/transaction/1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"SUCCESS\",\n  \"reason\": \"Manually confirmed by ops team\",\n  \"requested_by\": \"OPS-USER\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Overrides leg status. Sets mode=MANUAL. Does NOT increment attemptNumber. Valid statuses: SUCCESS, FAILED, PNDG. Replace '1' in the URL with the actual transaction_order from the posting response."
          }
        },
        {
          "name": "Manual Leg Status Override — FAILED (order=1)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}{{api_path}}/{{posting_id}}/transaction/1",
              "host": ["{{base_url}}{{api_path}}/{{posting_id}}/transaction/1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"FAILED\",\n  \"reason\": \"Target system confirmed rejection via phone\",\n  \"requested_by\": \"OPS-USER\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Replace '1' in the URL with the actual transaction_order from the posting response."
          }
        }
      ]
    },
    {
      "name": "Config",
      "item": [
        {
          "name": "List All Configs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}{{api_path}}/config",
              "host": ["{{base_url}}{{api_path}}/config"]
            },
            "description": "Returns all routing config entries across all request types."
          }
        },
        {
          "name": "Get Config by Request Type",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}{{api_path}}/config/IMX_CBS_GL",
              "host": ["{{base_url}}{{api_path}}/config/IMX_CBS_GL"]
            },
            "description": "Returns all ordered config entries for IMX_CBS_GL. Substitute any request_type in the URL."
          }
        },
        {
          "name": "Create Config — IMX_CBS_GL leg 1 (CBS, ASYNC)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}{{api_path}}/config",
              "host": ["{{base_url}}{{api_path}}/config"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"request_type\": \"IMX_CBS_GL\",\n  \"order_seq\": 1,\n  \"source_name\": \"IMX\",\n  \"target_system\": \"CBS\",\n  \"operation\": \"POSTING\",\n  \"processing_mode\": \"ASYNC\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Server assigns a config_id. The entry is identified by request_type + order_seq for update/delete."
          }
        },
        {
          "name": "Create Config — IMX_CBS_GL leg 2 (GL, ASYNC)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}{{api_path}}/config",
              "host": ["{{base_url}}{{api_path}}/config"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"request_type\": \"IMX_CBS_GL\",\n  \"order_seq\": 2,\n  \"source_name\": \"IMX\",\n  \"target_system\": \"GL\",\n  \"operation\": \"POSTING\",\n  \"processing_mode\": \"ASYNC\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Create Config — ADD_ACCOUNT_HOLD (CBS, SYNC)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}{{api_path}}/config",
              "host": ["{{base_url}}{{api_path}}/config"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"request_type\": \"ADD_ACCOUNT_HOLD\",\n  \"order_seq\": 1,\n  \"source_name\": \"STABLECOIN\",\n  \"target_system\": \"CBS\",\n  \"operation\": \"ADD_HOLD\",\n  \"processing_mode\": \"SYNC\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Update Config — IMX_CBS_GL/1",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}{{api_path}}/config/IMX_CBS_GL/1",
              "host": ["{{base_url}}{{api_path}}/config/IMX_CBS_GL/1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"target_system\": \"CBS\",\n  \"operation\": \"POSTING\",\n  \"source_name\": \"IMX\",\n  \"processing_mode\": \"SYNC\",\n  \"updated_by\": \"OPS-USER\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Updates config identified by {requestType}/{orderSeq} in the URL path. Substitute IMX_CBS_GL and 1 as needed. Only target_system, operation, source_name, processing_mode, and updated_by are modified."
          }
        },
        {
          "name": "Delete Config — IMX_CBS_GL/1",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}{{api_path}}/config/IMX_CBS_GL/1",
              "host": ["{{base_url}}{{api_path}}/config/IMX_CBS_GL/1"]
            },
            "description": "Deletes config identified by {requestType}/{orderSeq} in the URL path. Returns HTTP 204 No Content. Substitute IMX_CBS_GL and 1 as needed."
          },
          "response": [
            {
              "name": "204 No Content",
              "status": "No Content",
              "code": 204,
              "body": ""
            }
          ]
        }
      ]
    }
  ]
}
