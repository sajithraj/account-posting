    {
      "name": "02 - Search Postings",
      "item": [
        {
          "name": "Search All (No Filters)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{}"},
            "url": {
              "raw": "{{baseUrl}}/v2/payment/account-posting/search",
              "host": ["{{baseUrl}}"],
              "path": ["v2", "payment", "account-posting", "search"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has pagination fields', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.items).to.be.an('array');",
                  "    pm.expect(body.total_items).to.be.a('number');",
                  "});",
                  "pm.test('Save first postingId', () => {",
                  "    const body = pm.response.json();",
                  "    if (body.items && body.items.length > 0) {",
                  "        pm.collectionVariables.set('postingId', body.items[0].posting_id);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Search by Source Name (IMX)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"conditions\": [\n    {\"property\": \"source_name\", \"operator\": \"EQUALS\", \"values\": [\"IMX\"]}\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v2/payment/account-posting/search",
              "host": ["{{baseUrl}}"],
              "path": ["v2", "payment", "account-posting", "search"]
