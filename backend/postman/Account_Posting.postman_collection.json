          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('All results are IMX', () => {",
                  "    const body = pm.response.json();",
                  "    body.items.forEach(item => pm.expect(item.source_name).to.eql('IMX'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
