{
  "info": {
    "name": "Account Posting",
    "_postman_id": "account-posting-collection",
    "description": "Create, search, retrieve, and retry account postings",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:8080", "type": "string"},
    {"key": "postingId", "value": "", "type": "string"},
    {"key": "pendingPostingId", "value": "", "type": "string"}
  ],
  "item": [
    {
      "name": "01 - Create Posting",
      "item": [
        {
          "name": "IMX CBS+GL Posting",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_reference_id\": \"SRC-IMX-CBS-GL-001\",\n  \"end_to_end_reference_id\": \"E2E-IMX-CBS-GL-001\",\n  \"source_name\": \"IMX\",\n  \"request_type\": \"IMX_CBS_GL\",\n  \"amount\": {\n    \"value\": \"1000.00\",\n    \"currency_code\": \"USD\"\n  },\n  \"credit_debit_indicator\": \"CREDIT\",\n  \"debtor_account\": \"ACC-DEBTOR-001\",\n  \"creditor_account\": \"ACC-CREDITOR-001\",\n  \"requested_execution_date\": \"2026-03-31\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v2/payment/account-posting",
              "host": ["{{baseUrl}}"],
              "path": ["v2", "payment", "account-posting"]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const ts = Date.now();",
                  "const body = JSON.parse(pm.request.body.raw);",
                  "body.end_to_end_reference_id = 'E2E-IMX-CBS-GL-' + ts;",
                  "body.source_reference_id = 'SRC-IMX-CBS-GL-' + ts;",
                  "pm.request.body.raw = JSON.stringify(body);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Save postingId', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.source_reference_id).to.exist;",
                  "    pm.expect(body.posting_status).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
