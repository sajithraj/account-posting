          "name": "Retry Specific Posting IDs",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"posting_ids\": [{{pendingPostingId}}],\n  \"requested_by\": \"OPS-USER\"\n}"
