    {
      "name": "04 - Retry",
      "item": [
        {
          "name": "Retry All Pending Postings",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requested_by\": \"OPS-USER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v2/payment/account-posting/retry",
              "host": ["{{baseUrl}}"],
              "path": ["v2", "payment", "account-posting", "retry"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has retry summary', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.total_postings).to.be.a('number');",
                  "    pm.expect(body.success_count).to.be.a('number');",
                  "    pm.expect(body.failed_count).to.be.a('number');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
