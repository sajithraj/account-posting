{
  "info": {
    "name": "Posting Config",
    "_postman_id": "posting-config-collection",
    "description": "CRUD operations for posting configuration",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "configId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01 - Get All Configs",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v2/payment/posting-config",
          "host": ["{{baseUrl}}"],
          "path": ["v2", "payment", "posting-config"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns array', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "02 - Get Config by Request Type (IMX_CBS_GL)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v2/payment/posting-config/IMX_CBS_GL",
          "host": ["{{baseUrl}}"],
          "path": ["v2", "payment", "posting-config", "IMX_CBS_GL"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Correct request type', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.request_type).to.eql('IMX_CBS_GL');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
