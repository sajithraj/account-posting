{
  "info": {
    "name": "Posting Config",
    "_postman_id": "posting-config-collection",
    "description": "CRUD operations for posting configuration",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:8080", "type": "string"},
    {"key": "newConfigId", "value": "", "type": "string"}
  ],
  "item": [
    {
      "name": "01 - Get All Configs",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v2/payment/account-posting/config",
          "host": ["{{baseUrl}}"],
          "path": ["v2", "payment", "account-posting", "config"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns array', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "02 - Get Config by Request Type (IMX_CBS_GL)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v2/payment/account-posting/config/IMX_CBS_GL",
          "host": ["{{baseUrl}}"],
          "path": ["v2", "payment", "account-posting", "config", "IMX_CBS_GL"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns array with correct request type', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.be.an('array');",
              "    body.forEach(cfg => pm.expect(cfg.request_type).to.eql('IMX_CBS_GL'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "03 - Get Config by Request Type (IMX_OBPM)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v2/payment/account-posting/config/IMX_OBPM",
          "host": ["{{baseUrl}}"],
          "path": ["v2", "payment", "account-posting", "config", "IMX_OBPM"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "04 - Get Config by Request Type (RMS_FED_RETURN)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v2/payment/account-posting/config/RMS_FED_RETURN",
          "host": ["{{baseUrl}}"],
          "path": ["v2", "payment", "account-posting", "config", "RMS_FED_RETURN"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "05 - Get Config by Request Type (empty result)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v2/payment/account-posting/config/UNKNOWN_TYPE",
          "host": ["{{baseUrl}}"],
          "path": ["v2", "payment", "account-posting", "config", "UNKNOWN_TYPE"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 empty array', () => {",
              "    pm.response.to.have.status(200);",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.be.an('array').that.is.empty;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "06 - Create Config (CBS row)",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source_name\": \"IMX\",\n  \"request_type\": \"IMX_TEST_TYPE\",\n  \"target_system\": \"CBS\",\n  \"operation\": \"POSTING\",\n  \"order_seq\": 1,\n  \"requested_by\": \"OPS-USER\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v2/payment/account-posting/config",
          "host": ["{{baseUrl}}"],
          "path": ["v2", "payment", "account-posting", "config"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.test('Has correct fields', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.config_id).to.exist;",
              "    pm.expect(body.source_name).to.eql('IMX');",
              "    pm.expect(body.request_type).to.eql('IMX_TEST_TYPE');",
              "    pm.expect(body.target_system).to.eql('CBS');",
              "    pm.expect(body.order_seq).to.eql(1);",
              "    pm.collectionVariables.set('newConfigId', body.config_id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "07 - Create Config (GL row for same request type)",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source_name\": \"IMX\",\n  \"request_type\": \"IMX_TEST_TYPE\",\n  \"target_system\": \"GL\",\n  \"operation\": \"POSTING\",\n  \"order_seq\": 2,\n  \"requested_by\": \"OPS-USER\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v2/payment/account-posting/config",
          "host": ["{{baseUrl}}"],
          "path": ["v2", "payment", "account-posting", "config"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.test('order_seq is 2', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.order_seq).to.eql(2);",
              "    pm.expect(body.target_system).to.eql('GL');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "08 - Create Config Duplicate order_seq (422)",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source_name\": \"IMX\",\n  \"request_type\": \"IMX_TEST_TYPE\",\n  \"target_system\": \"OBPM\",\n  \"operation\": \"POSTING\",\n  \"order_seq\": 1,\n  \"requested_by\": \"OPS-USER\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v2/payment/account-posting/config",
          "host": ["{{baseUrl}}"],
          "path": ["v2", "payment", "account-posting", "config"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));",
              "pm.test('Error DUPLICATE_CONFIG_ORDER', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.name).to.eql('DUPLICATE_CONFIG_ORDER');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "09 - Create Config Missing Required Fields (400)",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source_name\": \"IMX\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v2/payment/account-posting/config",
          "host": ["{{baseUrl}}"],
          "path": ["v2", "payment", "account-posting", "config"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));",
              "pm.test('Error VALIDATION_FAILED', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.name).to.eql('VALIDATION_FAILED');",
              "    pm.expect(body.errors).to.be.an('array').with.length.above(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "10 - Update Config",
      "request": {
        "method": "PUT",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source_name\": \"IMX\",\n  \"request_type\": \"IMX_CBS_GL\",\n  \"target_system\": \"CBS\",\n  \"operation\": \"POSTING\",\n  \"order_seq\": 1,\n  \"requested_by\": \"OPS-USER\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v2/payment/account-posting/config/1",
          "host": ["{{baseUrl}}"],
          "path": ["v2", "payment", "account-posting", "config", "1"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Updated correctly', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.request_type).to.eql('IMX_CBS_GL');",
              "    pm.expect(body.target_system).to.eql('CBS');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "11 - Update Config Not Found (404)",
      "request": {
        "method": "PUT",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source_name\": \"IMX\",\n  \"request_type\": \"GHOST_TYPE\",\n  \"target_system\": \"CBS\",\n  \"operation\": \"POSTING\",\n  \"order_seq\": 1,\n  \"requested_by\": \"OPS-USER\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v2/payment/account-posting/config/99999",
          "host": ["{{baseUrl}}"],
          "path": ["v2", "payment", "account-posting", "config", "99999"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 404', () => pm.response.to.have.status(404));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "12 - Delete Config (CBS row created in step 06)",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v2/payment/account-posting/config/{{newConfigId}}",
          "host": ["{{baseUrl}}"],
          "path": ["v2", "payment", "account-posting", "config", "{{newConfigId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 204', () => pm.response.to.have.status(204));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "13 - Delete Config Not Found (404)",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v2/payment/account-posting/config/99999",
          "host": ["{{baseUrl}}"],
          "path": ["v2", "payment", "account-posting", "config", "99999"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 404', () => pm.response.to.have.status(404));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
