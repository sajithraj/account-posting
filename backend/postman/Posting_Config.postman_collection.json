    },
    {
      "name": "05 - Get Config Not Found (404)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v2/payment/posting-config/UNKNOWN_TYPE",
          "host": ["{{baseUrl}}"],
          "path": ["v2", "payment", "posting-config", "UNKNOWN_TYPE"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 404', () => pm.response.to.have.status(404));",
              "pm.test('Error name NOT_FOUND', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.name).to.eql('NOT_FOUND');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "06 - Create Config",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source_name\": \"IMX\",\n  \"request_type\": \"IMX_NEW_TYPE\",\n  \"legs\": [\n    {\n      \"target_system\": \"CBS\",\n      \"operation\": \"POSTING\",\n      \"order_seq\": 1\n    },\n    {\n      \"target_system\": \"GL\",\n      \"operation\": \"POSTING\",\n      \"order_seq\": 2\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v2/payment/posting-config",
          "host": ["{{baseUrl}}"],
          "path": ["v2", "payment", "posting-config"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.test('Has config_id', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.config_id).to.exist;",
              "    pm.collectionVariables.set('configId', body.config_id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "07 - Create Config Duplicate Order Seq (422)",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source_name\": \"IMX\",\n  \"request_type\": \"IMX_CBS_GL\",\n  \"legs\": [\n    {\n      \"target_system\": \"CBS\",\n      \"operation\": \"POSTING\",\n      \"order_seq\": 1\n    },\n    {\n      \"target_system\": \"GL\",\n      \"operation\": \"POSTING\",\n      \"order_seq\": 1\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v2/payment/posting-config",
          "host": ["{{baseUrl}}"],
          "path": ["v2", "payment", "posting-config"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 422 or 400', () => {",
              "    pm.expect(pm.response.code).to.be.oneOf([400, 422]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
